// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
//prisma-cest/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@cest/client"
}

datasource db {
  provider = "postgresql"
}

model certificacion {
  id                Int
  nombre            String?
  paterno           String?
  materno           String?
  cedula            String?
  taller            String?
  codigo_esfm       Int?
  esfm              String?
  departamento      String?
  lengua_originaria String?
  nivel             String?
  carga_horaria     Int?
  gestion           Int?
  fecha_inicio      DateTime?
  codigo_estudiante String?
  taller2           String?
  valida_datos      Int?
  cantidad_datos    Int?
  dato_corregido    Int?
  tacfi             String?
  especialidad      String?
  hoja_ruta         Int?

  @@id([id])
}

model certificacion_persona {
  cod_pers String  @id
  nombre   String?
  paterno  String?
  materno  String?
  cedula   String?
}

model certificacionTACFI {
  id                Int       @id
  nombre            String?
  paterno           String?
  materno           String?
  cedula            String?
  taller            String?
  codigo_esfm       Int?
  esfm              String?
  departamento      String?
  lengua_originaria String?
  nivel             String?
  carga_horaria     Int?
  gestion           Int?
  fecha_inicio      DateTime?
  codigo_estudiante String?
  observacion       String?
  dato_corregido    Int?
  tacfi             String?
  especialidad      String?
  hoja_ruta         Int?
}

model certificacionTCLO {
  id                Int       @id
  nombre            String?
  paterno           String?
  materno           String?
  cedula            String?
  taller            String?
  codigo_esfm       Int?
  esfm              String?
  departamento      String?
  lengua_originaria String?
  nivel             String?
  carga_horaria     Int?
  gestion           Int?
  fecha_inicio      DateTime?
  codigo_estudiante String?
  observacion       String?
  dato_corregido    Int?
  hoja_ruta         Int?
}

model esfms {
  id               Int       @id
  cod_esfm         Int
  type_esfm        String?
  name             String?
  department_id    Int?
  created_at       DateTime?
  updated_at       DateTime?
  address          String?
  nombre_cert      String?
  nombre_cert_tclo String?
}
