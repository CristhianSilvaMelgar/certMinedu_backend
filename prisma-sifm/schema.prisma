//prisma-cest/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@sifm/client"
}

datasource db {
  provider = "mysql"
}

model t_personas {
  cod_pers  String  @id
  nombre1   String?
  nombre2   String?
  apellido1 String?
  apellido2 String?
  nro_docum String?
}

model t_ins {
  cod_ins Int     @id
  tipo    String?
  nom_ins String?
  cod_dep Int?
}
